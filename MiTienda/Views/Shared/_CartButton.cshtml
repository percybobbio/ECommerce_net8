@using MiTienda.Utilities;
@using Microsoft.AspNetCore.Http

@{
    int CartItemCount = 0;
    if(Context.Session.GetCarrito<List<CarritoItemVM>>("Carrito") != null)
    {
        var carrito = Context.Session.GetCarrito<List<CarritoItemVM>>("Carrito");
        CartItemCount = carrito.Count();
    }
}

<li class="nav-item ms-auto">
    <a class="btn btn-outline-dark" asp-controller="Home" asp-action="ViewCart">
        <i class="fa-solid fa-cart-shopping"></i>
        Carrito
        <span class="badge bg-dark text-white ms-1 rounded-pill">@CartItemCount</span>
    </a>
</li>