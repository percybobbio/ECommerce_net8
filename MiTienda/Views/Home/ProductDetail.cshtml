@model ProductoVM;

<section class="py-5 bg-body-tertiary">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row g-4 g-lg-5 align-items-center">
            <div class="col-md-4">
                <img class="card-img-top rounded mb-5" src="~/images/@Model.NombreImagen" alt="@Model.Nombre" loading="lazy" />
            </div>
            <div class="col-md-8">
                <h1 class="display-5 mb-3 fw-bolder">@Model.Nombre</h1>
                <div class="fs-5 mb-4">
                    <span class="text-primary fw-semibold ms-2">@Model.Precio.ToString("C2")</span>
                </div>
                <p class="lead">@Html.Raw(Model.Descripcion)</p>
                <form asp-controller="Home" asp-action="AddItemToCart" method="post">
                    <div class="d-flex align-items-center gap-3">
                        <input hidden name="productoId" asp-for="@Model.IdProducto"/>
                        @if (Model.Stock > 0)
                        {
                            <input type="number" name="cantidad" value="1" min="1" max="@Model.Stock" class="form-control text-center py-2" style="max-width:5rem" />
                            
                        }
                        else
                        {
                            <input type="number" class="form-control text-center" value="0" disabled style="max-width:5rem" />
                            <span class="text-danger fw-bold ms-3">¡Producto Agotado!</span>
                        }

                        <button class="btn btn-dark flex-xl-shrink-0 px-4" type="submit"><i class="fa-solid fa-cart-plus"></i> Agregar al Carrito</button>
                        <button class="btn btn-outline-secondary flex-xl-shrink-0 px-4 py-2" type="button"><i class="fa-solid fa-heart"></i> Agregar a Favoritos</button>
                        <a class="btn btn-warning flex-md-shrink-0 px-4" asp-controller="Home" asp-action="Index">Retornar</a>
                    </div>                    
                </form>

                @if(ViewBag.mensaje != null)
                {
                    <div class="alert alert-info mt-4" role="alert">
                        @ViewBag.mensaje
                    </div>
                }
            </div>
        </div>
    </div>
</section>
