@model CategoriaVM

@{
    var titulo = Model.IdCategoria == 0 ? "Nueva Categoría" : "Editar Categoría";
    var btnAccion = Model.IdCategoria == 0 ? "Agregar nueva" : "Guardar Cambios";
}

<div class="row">
    <div class="col-6">
        <h2>@titulo</h2>
        <hr />
        <form method="post" action="/Categoria/AddEdit">
            <input type="hidden" asp-for="IdCategoria" value="@Model.IdCategoria" />
            @if(Model.IdCategoria == 0)
            {
                @* //Agrega el valor del campo Activo como true por defecto *@
                <input type="hidden" asp-for="Activo" value="true" />
            }
            else
            {
                <div class="form-check form-switch mb-3 mt-3">
                    <input class="form-check-input" type="checkbox" asp-for="Activo" />
                    <label class="form-check-label" asp-for="Activo">Categoria Activa</label>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label">Descripción</label>
                <input type="text" asp-for="Descripcion" class="form-control" autocomplete="off"/>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
            <div asp-validation-summary="All" class="text-danger font-weight-bold"></div>
            @if(ViewBag.mensaje != null)
            {
               <div class="alert alert-success" role="alert">
                    @ViewBag.mensaje
               </div>
            }
            <div class="d-grid gap-2 d-md-block mt-4">
                <button type="submit" class="btn btn-primary">@btnAccion <i class="fa-solid fa-floppy-disk"></i></button>
                <a asp-controller="Categoria" asp-action="Index" class="btn btn-secondary">Retornar <i class="fa-solid fa-arrow-left"></i></a>

            </div>
        </form>

    </div>
</div>
