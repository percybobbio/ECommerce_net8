@model List<ProductoVM>

<div class="row justify-content-between mt-4">
    <div class="col-4">
        <h4>Productos</h4>
    </div>
    <div class="col-4 text-end">
        <a href="/Producto/AddEdit" class="btn btn-success">Crear Nuevo <i class="fa-solid fa-circle-plus"></i></a>
    </div>

</div>
<hr />
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Estado</th>
            <th>Fecha Registro</th>
            <th>Categoria</th>
            <th>Marca</th>
            <th style="width: 120px">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@Html.Raw(item.Descripcion)</td>
                <td>@item.Precio.ToString("C")</td>
                <td>@item.Stock</td>
                <td>
                    <span class="badge @item.EstadoColor">
                        @item.EstadoTexto
                    </span>
                </td>
                <td>@item.FechaRegistro?.ToString("dd/MM/yyyy")</td>
                <td>@item.Categoria.Descripcion</td>
                <td>@item.Marca.Descripcion</td>
                <td style="width: 200px">
                    <a asp-controller="Producto" asp-action="AddEdit" asp-route-id="@item.IdProducto" class="btn btn-sm btn-primary"><i class="fa-solid fa-pen"></i> Editar</a>
                    <button class="btn btn-sm btn-danger" onclick="deleteProducto(@item.IdProducto)"><i class="fa-solid fa-trash"></i> Eliminar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {

    <script>
        function deleteProducto(id){

          Swal.fire({
          title: "Esta seguro de eliminar?",
          icon: "warning",
          showCancelButton: true,
          confirmButtonColor: "#3085d6",
          cancelButtonColor: "#d33",
          confirmButtonText: "Si, eliminar!",
          cancelButtonText: "No, Regresar!"
        }).then((result) => {
          if (result.isConfirmed) {
            fetch(`/Producto/Delete/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Recargar la página o eliminar la fila de la tabla
                        location.reload();
                    } else {
                        alert("Error al eliminar el producto.");
                    }
                })
                .catch(error => console.error('Error:', error));
            }

        });
        }
    </script>
}

