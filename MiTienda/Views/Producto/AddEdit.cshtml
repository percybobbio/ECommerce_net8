@model ProductoVM

@{
    var titulo = Model.IdProducto == 0 ? "Nuevo Producto" : "Editar Producto";
    var btnAccion = Model.IdProducto == 0 ? "Agregar nuevo" : "Guardar Cambios";
}

<div class="row">
    <h2>@titulo</h2>
    <hr />
    <div class="col-6">
        <form method="post" action="/Producto/AddEdit" enctype="multipart/form-data">
            <input type="hidden" asp-for="IdProducto" value="@Model.IdProducto" />
            @if (Model.IdProducto == 0)
            {
                @* //Agrega el valor del campo Activo como true por defecto *@
                <input type="hidden" asp-for="Activo" value="true" />
            }
            else
            {
                <div class="form-check form-switch mb-3 mt-3">
                    <input class="form-check-input" type="checkbox" asp-for="Activo" />
                    <label class="form-check-label" asp-for="Activo">Producto Activo</label>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label">Nombre</label>
                <input type="text" asp-for="Nombre" class="form-control" autocomplete="off" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" id="txtDescripcion" class="form-control" autocomplete="off"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label">Precio</label>
                <input type="number" asp-for="Precio" class="form-control" autocomplete="off" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Stock" class="form-label">Stock</label>
                <input type="number" asp-for="Stock" class="form-control" autocomplete="off" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="NombreImagen" />
            <input type="hidden" asp-for="RutaImagen" />

            <div class="mb-3">
                <label asp-for="ArchivoImagen" class="form-label">Subir Imagen</label>
                <input type="file" asp-for="ArchivoImagen" class="form-control" accept="image/*"/>
            </div>

            <div class="mb-3">
                <label asp-for="Categoria.IdCategoria" class="form-label">Categoría</label>
                <select class="form-select" asp-for="Categoria.IdCategoria" asp-items="@Model.listaCategorias">
                    <option selected disabled>--seleccionar--</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Marca.IdMarca" class="form-label">Marca</label>
                <select class="form-select" asp-for="Marca.IdMarca" asp-items="@Model.listaMarcas">
                    <option selected disabled>--seleccionar--</option>
                </select>
            </div>
            @if (ViewBag.mensaje != null)
            {
                <div class="alert alert-success" role="alert">
                    @ViewBag.mensaje
                </div>
            }
            <div class="d-grid gap-2 d-md-block mt-4">
                <button type="submit" class="btn btn-primary">@btnAccion <i class="fa-solid fa-floppy-disk"></i></button>
                <a asp-controller="Producto" asp-action="Index" class="btn btn-secondary">Retornar <i class="fa-solid fa-arrow-left"></i></a>

            </div>
        </form>
        <div asp-validation-summary="All" class="text-danger fw-bold"></div>

    </div>
    <div class="col-6">
        <img src="~/images/@Model.NombreImagen" class="rounded" width="300" height="320" alt="@Model.Nombre" />
    </div>
</div>

@section Styles {
    <link href="~/lib/summernote/dist/summernote.min.css" rel="stylesheet" />
    <link href="~/lib/summernote/dist/summernote-bs5.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="~/lib/summernote/dist/summernote.min.js"></script>
    <script src="~/lib/summernote/dist/summernote-bs5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#txtDescripcion').summernote({
                height: 150,
                placeholder: 'Escribe la descripción detallada del producto aquí...',
                tabsize: 2
            });
        });
    </script>
}
